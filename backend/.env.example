# 后端环境变量示例（用于阿里云短信/号码认证 SDK）
#
# 注意：
# 1. `.env` 会被加入 `.gitignore`，不要提交到远程仓库。
# 2. 需要把下面的 AK/SK 替换成你自己的。
#
# 阿里云 AccessKey
# .env.example - 提交到仓库的模板文件
# 注意：不要填写真实的值！

ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id_here
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret_here

# 服务端监听（保持与代码默认一致即可）
# 公网服务器用的是3005
PORT=3005
HOST=0.0.0.0
# 服务器公网访问地址（用于生成文件访问URL）
SERVER_BASE_URL=http://1.15.45.125:3005

# MySQL 数据库连接
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here  # 不要填真实密码
DB_NAME=carpooling

# JWT 密钥（示例值）
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# 生产环境建议设为 production；开发可不设
# NODE_ENV=production

# 仅当 NODE_ENV=production 时生效：设为 true 才在「发送验证码」成功响应里带回 verifyCode（联调/测试用，生产勿开）
# ALLOW_RETURN_VERIFY_CODE=true

