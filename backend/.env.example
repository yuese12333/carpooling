# 后端环境变量示例（用于阿里云短信/号码认证 SDK）
#
# 注意：
# 1. `.env` 会被加入 `.gitignore`，不要提交到远程仓库。
# 2. 需要把下面的 AK/SK 替换成你自己的。
#
# 阿里云 AccessKey
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# 服务端监听（保持与代码默认一致即可）
PORT=3000
HOST=0.0.0.0

# MySQL 数据库连接
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=carpooling
# 连接池最大连接数
DB_CONNECTION_LIMIT=10

# 生产环境建议设为 production；开发可不设
# NODE_ENV=production

# 仅当 NODE_ENV=production 时生效：设为 true 才在「发送验证码」成功响应里带回 verifyCode（联调/测试用，生产勿开）
# ALLOW_RETURN_VERIFY_CODE=true

