# 后端 API 根地址（不要以 / 结尾）
# 开发环境：内网（本机或局域网 IP）
EXPO_PUBLIC_API_URL=http://localhost:3000
# 或本机局域网 IP，便于真机访问同一后端：
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# 测试环境：公网服务器
# EXPO_PUBLIC_API_URL=https://api-test.yourdomain.com

# 高德地图（https://console.amap.com/ 应用管理中的 Key 名称与安全密钥 Key）
# EXPO_PUBLIC_ 前缀会在打包时注入到 JS 可访问环境变量
EXPO_PUBLIC_AMAP_KEY_NAME=carpooling
EXPO_PUBLIC_AMAP_API_KEY=请替换为你的高德_Key
